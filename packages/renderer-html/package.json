{
  "name": "@jaroslava/renderer-html",
  "version": "1.0.1",
  "description": "Renders the Jaroslava AST to HTML + CSS. Dispatches per-component rendering to plugins; framework-agnostic, works in Node and the browser (SSR/SSG-ready).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@jaroslava/types": "workspace:*",
    "@jaroslava/utils": "workspace:*",
    "@jaroslava/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "rimraf": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
