{
  "name": "@jaroslava/parser",
  "version": "0.1.0",
  "description": "Converts Jaroslava (.jaro) source text into the Jaroslava AST. Plugin-aware: unknown component kinds are handled generically.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@jaroslava/types": "workspace:*",
    "@jaroslava/utils": "workspace:*",
    "@jaroslava/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "rimraf": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
