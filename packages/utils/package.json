{
  "name": "@jaroslava/utils",
  "version": "1.0.1",
  "description": "Framework-agnostic helpers shared across the Jaroslava SDK: AST traversal, id generation, string/indent helpers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@jaroslava/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "rimraf": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
