{
  "name": "@jaroslava/core",
  "version": "1.0.1",
  "description": "Plugin registry and core runtime for the Jaroslava SDK. Owns the component/plugin contract that parser, validator and renderer-html all depend on.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@jaroslava/types": "workspace:*",
    "@jaroslava/utils": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "rimraf": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
